{
  "$schema": "https://railway.app/railway.schema.json",
  "services": {
    "go-tracking-core": {
      "build": {
        "builder": "dockerfile",
        "context": "./go-tracking-core",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "startCommand": "./tracker-service",
        "port": 8080
      },
      "variables": {
        "REDIS_ADDR": "${{ Redis.host }}:${{ Redis.port }}",
        "PORT": "8080"
      }
    },
    "php-control-plane": {
      "build": {
        "builder": "dockerfile",
        "context": "./php-control-plane",
        "dockerfile": "Dockerfile"
      },
      "deploy": {
        "port": 80
      },
      "variables": {
        "DB_HOST": "${{ MySQL.host }}",
        "DB_NAME": "railway_db",
        "DB_USER": "railway_user",
        "DB_PASS": "${{ MySQL.password }}",
        "REDIS_HOST": "${{ Redis.host }}",
        "REDIS_PORT": "${{ Redis.port }}"
      }
    },
    "transit-python-cluster": {
      "build": {
        "builder": "dockerfile",
        "context": "./transit-python-cluster",
        "dockerfile": "Dockerfile"
      },
      "variables": {
        "REDIS_HOST": "${{ Redis.host }}",
        "REDIS_PORT": "${{ Redis.port }}"
      }
    }
  },
  "plugins": {
    "redis": {
      "type": "redis",
      "version": "7"
    },
    "mysql": {
      "type": "mysql",
      "version": "8.0"
    }
  }
}
